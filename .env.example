# =============================================================================
# REQUIRED CONFIGURATION
# =============================================================================

# Telegram Bot Token
# Get this from @BotFather on Telegram:
# 1. Start a chat with @BotFather
# 2. Send /newbot
# 3. Follow instructions to create bot
# 4. Copy the HTTP API token here
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Your Telegram User ID(s) - comma-separated for multiple accounts
# Get this from @userinfobot on Telegram:
# 1. Start a chat with @userinfobot
# 2. It will reply with your ID
# 3. Copy the numeric ID(s) here (no quotes)
#
# Single user: ALLOWED_USER_IDS=123456789
# Multiple users: ALLOWED_USER_IDS=123456789,987654321
ALLOWED_USER_IDS=123456789

# =============================================================================
# OPTIONAL CONFIGURATION
# =============================================================================

# Taskwarrior config file path inside container
# Default: /root/.taskrc
# TASKRC_PATH=/root/.taskrc

# Taskwarrior data directory inside container
# Default: /root/.task
# TASK_DATA_DIR=/root/.task

# Logging level (DEBUG, INFO, WARNING, ERROR)
# Default: INFO
# LOG_LEVEL=INFO
